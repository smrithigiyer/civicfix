# CivicFix Environment Configuration Example
# ==========================================
# Copy this file to .env and update values for your deployment

# Flask Environment (development, production, lan)
FLASK_ENV=development

# Secret Keys (CHANGE THESE IN PRODUCTION!)
# Generate secure keys with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_SECRET_KEY=change-this-to-another-secure-random-string-in-production

# MongoDB Configuration
# Format: mongodb://[username:password@]host:port/database
MONGO_URI=mongodb://localhost:27017/civicfix

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Debug Mode (set to False in production)
DEBUG=True

# Google Maps API Configuration
GOOGLE_MAPS_API_KEY=AIzaSyD4-ctovS8sIQh7FsEB06iFOhDrSAtZn8w

# Admin Registration Security
# IMPORTANT: Change this secret key before deploying to production!
ADMIN_ACCESS_KEY=CIVICFIX-ADMIN-2024-SECURE
